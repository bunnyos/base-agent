# Copy to .env and fill in real values: cp .env.example .env

# Postgres connection string.
DATABASE_URL=postgres://user:password@host:5432/dbname

# >=16-char secret; signs session cookies and encrypts stored API keys + wallet tokens. Rotating it logs everyone out and orphans encrypted rows.
# Generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-a-32-byte-random-hex-string

# Public base path the interface is served under; use "/" for local dev.
BASE_PATH=/
